# ====================================================================
# JobS2 — 环境变量配置模板
# ====================================================================
# 复制本文件为 .env 并填入实际值：
#   cp .env.example .env
#   # 然后编辑 .env 文件
#
# 若使用 Docker Compose 部署，这些变量也会被 docker-compose.yaml 读取
# ====================================================================

# ── Docker Hub 镜像拉取 ──
# 注意：该值与 GitHub Actions secrets.DOCKERHUB_USERNAME 保持一致
DOCKERHUB_USERNAME=your_dockerhub_username

# ── 飞书 Webhook 通知（必填） ──
# BOT 运行状态、扫码需求、异常告警均通过此 Webhook 推送到飞书群
BOT_LARK_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxx

# ── 搜索配置（可选） ──
# Boss 直聘搜索 URL，默认 Python 上海
BOT_SEARCH_URL=https://www.zhipin.com/web/geek/job?query=Python&city=101020100
# 每轮检索扫描页数
BOT_PAGES_TO_SCAN=3

# ── 轮询间隔（可选，默认 300 秒） ──
# 每轮检索完成后的休眠时间
BOT_CHECK_INTERVAL=300

# ── 人性化延迟（可选） ──
# 模拟人类操作的随机等待时间范围（秒）
BOT_MIN_DELAY=3.0
BOT_MAX_DELAY=7.0

# ── 每日限制（可选） ──
# 每日自动沟通上限（建议 100-200）
BOT_DAILY_CHAT_LIMIT=150
# 连续空结果触发告警阈值
BOT_MAX_CONSECUTIVE_EMPTY=3

# ── Chromium 配置（可选） ──
# headless=true 时浏览器在后台运行（Docker 内建议保持 false，由 xvfb 处理）
BOT_HEADLESS=false